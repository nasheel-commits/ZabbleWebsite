# ─────────────────────────────────────────────────────────────────────────────
# Zabble SEO/AEO/GEO — environment variable template.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `.env` and `.env.*` are git-ignored (see .gitignore); only this `.env.example`
# (no secrets) is tracked. See docs/seo/00-access-and-credentials.md.
# ─────────────────────────────────────────────────────────────────────────────

# DataForSEO API credentials.
# USERNAME = your DataForSEO API login (the account email).
# PASSWORD = the API password shown in the dashboard "API CREDENTIALS" block
#            at https://app.dataforseo.com/api-access  — this is NOT your
#            website/login password. Auth is HTTP Basic (username:password).
DATAFORSEO_USERNAME=you@example.com
DATAFORSEO_PASSWORD=your_api_password_here

# Basic-auth token for the HOSTED MCP server (https://mcp.dataforseo.com/http).
# It is base64("username:password"). Generate it with:
#   printf '%s' "$DATAFORSEO_USERNAME:$DATAFORSEO_PASSWORD" | base64
# Referenced by .mcp.json as ${DATAFORSEO_BASIC_AUTH} (so the token never lands
# in git). Regenerate whenever the API password changes.
DATAFORSEO_BASIC_AUTH=base64_of_username_colon_password

# Which DataForSEO MCP tool groups Claude Code may use. COMMA-separated, no spaces.
# Valid: AI_OPTIMIZATION, SERP, KEYWORDS_DATA, ONPAGE, DATAFORSEO_LABS, BACKLINKS,
#        BUSINESS_DATA, DOMAIN_ANALYTICS, CONTENT_ANALYSIS, MERCHANT.
# Omit the variable entirely to enable ALL modules.
ENABLED_MODULES=SERP,KEYWORDS_DATA,DATAFORSEO_LABS,ONPAGE,BACKLINKS,DOMAIN_ANALYTICS,AI_OPTIMIZATION,CONTENT_ANALYSIS

# Free sandbox base URL — returns dummy data, never billed. Used for wiring/CI
# checks. Live base URL is https://api.dataforseo.com (billed per call).
DATAFORSEO_SANDBOX_URL=https://sandbox.dataforseo.com
