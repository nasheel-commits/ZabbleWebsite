{
  "name": "Our-Website",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "gen:llms": "node scripts/gen-llms-full.cjs",
    "test": "cross-env NUXT_SITE_INDEXABLE=true nuxt generate && npm run test:vitest && npm run test:node && npm run test:scripts",
    "test:vitest": "vitest run",
    "test:node": "node --test tests/architecture.test.mjs tests/geo.test.mjs",
    "test:scripts": "node scripts/seo-metadata.test.mjs",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/seo/seo-logic.test.ts",
    "test:seo": "cross-env NUXT_SITE_INDEXABLE=true nuxt generate && vitest run",
    "test:arch": "node --test tests/architecture.test.mjs",
    "test:aeo": "vitest run test/aeo-data.spec.ts",
    "test:aeo:rendered": "vitest run test/aeo-rendered.spec.ts",
    "test:geo": "node --test tests/geo.test.mjs",
    "test:metadata": "node scripts/seo-metadata.test.mjs",
    "verify:seo": "cross-env NUXT_SITE_INDEXABLE=true nuxt generate && node scripts/seo-metadata.test.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@nuxtjs/seo": "^5.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "nuxt": "^4.4.6",
    "nuxt-schema-org": "^6.0.4",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.14.0",
    "cross-env": "^7.0.3",
    "nuxt-link-checker": "^5.0.10",
    "vitest": "^3.2.4"
  }
}
